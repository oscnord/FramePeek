      "comment" : "A value label on the y-axis of the frame intervals chart, showing the frame interval in milliseconds.",
      "isCommentAutoGenerated" : true
    },
    "%.2f" : {
      "comment" : "A value label on the brightness chart, showing the brightness value with two decimal places.",
      "isCommentAutoGenerated" : true
    },
    "%.2f s" : {
      "comment" : "A stepper control that lets the user set the interval at which the app samples the camera feed for new pixel data. The value displayed is formatted to two decimal places.",
      "isCommentAutoGenerated" : true
    },
    "%@ • %@" : {
      "comment" : "A text view displaying the video resolution and codec.",
      "isCommentAutoGenerated" : true,
      "localizations" : {

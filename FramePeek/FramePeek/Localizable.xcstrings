  "strings" : {
    "" : {

    },
    "–" : {

    },
    "/ %@" : {
      "comment" : "A label showing the current playback time of a video, followed by a separator and the total duration of the video. The argument is the string “%1$d:%2$02d:%3$02d” or the string “%1$d:%2$02d”.",
      "isCommentAutoGenerated" : true
    },
    "%.0f" : {
      "comment" : "A y-axis label displaying the bitrate in kilobits per second.",
      "isCommentAutoGenerated" : true
    },
    "%.2f s" : {
      "comment" : "A stepper control that lets the user set the interval at which the app samples the camera feed for new pixel data. The value displayed is formatted to two decimal places.",
      "isCommentAutoGenerated" : true
    },
    "%@ • %@" : {
      "comment" : "A text view displaying the video resolution and codec.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ • %2$@"
          }
        }
      }
    },
    "%@ kb/s" : {
      "comment" : "A label displaying the bitrate of a sample in kilobits per second. The value is formatted to show no more than 0 decimal places.",
      "isCommentAutoGenerated" : true
    },
    "%@ s" : {
      "comment" : "A label displaying the time and bitrate of a sample. The first argument is the time of the sample, formatted to two decimal places. The second argument is the bitrate of the sample, formatted to one decimal",
      "isCommentAutoGenerated" : true
    },
    "%lld" : {
      "comment" : "A text field displaying the number of samples to collect during an analysis. The text is monospaced to improve readability.",
      "isCommentAutoGenerated" : true
    },
    "%lld pts" : {
      "comment" : "A label displaying the number of data points currently being analyzed. The argument is the number of samples currently being analyzed.",
      "isCommentAutoGenerated" : true
    },
    "%lld/%lld" : {
      "comment" : "A label showing the current keyframe index and the total number of keyframes. The first argument is the 1-based index of the currently hovered keyframe. The second argument is the total count of keyframes.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$lld/%2$lld"
          }
        }
      }
    },
